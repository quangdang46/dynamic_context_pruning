{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CacheStabilityMode": {
      "description": "Internal phantom type used purely by [`schemars::JsonSchema`] when generating the JSON schema for a [`crate::Config`] field of type [`CacheStabilityMode`]. Callers should never use this type directly.",
      "oneOf": [
        {
          "description": "Apply on every transform — debug-only.",
          "enum": [
            "aggressive"
          ],
          "type": "string"
        },
        {
          "description": "Apply at turn boundaries — default.",
          "enum": [
            "agent-message"
          ],
          "type": "string"
        },
        {
          "description": "Apply only when the host calls `force_apply()`.",
          "enum": [
            "manual"
          ],
          "type": "string"
        }
      ]
    },
    "CommandsConfig": {
      "description": "Slash-command surface configuration (SPEC.md §10.2 — `commands`).",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Master switch for the `/dcp …` slash-command surface.",
          "type": "boolean"
        },
        "protectedTools": {
          "default": [],
          "description": "Tools the `/dcp sweep` command pre-protects.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "CompressConfig": {
      "description": "Configuration for the `compress` tool (SPEC.md §10.2 — `compress`).",
      "properties": {
        "iterationNudgeThreshold": {
          "default": 15,
          "description": "Iteration nudge threshold. Range: `2..=100`, default `15`.",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "maxContextLimit": {
          "allOf": [
            {
              "$ref": "#/definitions/LimitValue"
            }
          ],
          "default": 100000,
          "description": "Resolved or raw maximum context limit (number or `\"X%\"`)."
        },
        "maxSummaryChars": {
          "default": 32768,
          "description": "Per-entry summary length cap. Range: `1024..=262144`, default `32768`.",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "minContextLimit": {
          "allOf": [
            {
              "$ref": "#/definitions/LimitValue"
            }
          ],
          "default": 50000,
          "description": "Resolved or raw minimum context limit."
        },
        "mode": {
          "allOf": [
            {
              "$ref": "#/definitions/CompressMode"
            }
          ],
          "default": "range",
          "description": "Active mode (`\"range\" | \"message\"`, default `range`)."
        },
        "modelMaxLimits": {
          "additionalProperties": {
            "$ref": "#/definitions/LimitValue"
          },
          "default": {},
          "description": "Per-model overrides for `maxContextLimit`.",
          "type": "object"
        },
        "modelMinLimits": {
          "additionalProperties": {
            "$ref": "#/definitions/LimitValue"
          },
          "default": {},
          "description": "Per-model overrides for `minContextLimit`.",
          "type": "object"
        },
        "nudgeForce": {
          "allOf": [
            {
              "$ref": "#/definitions/NudgeForce"
            }
          ],
          "default": "soft",
          "description": "Tone of nudge text (`\"strong\" | \"soft\"`, default `soft`)."
        },
        "nudgeFrequency": {
          "default": 5,
          "description": "Re-fire frequency for context-limit nudges. Range: `1..=100`, default `5`.",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "permission": {
          "allOf": [
            {
              "$ref": "#/definitions/Permission"
            }
          ],
          "default": "allow",
          "description": "Permission gating (`\"ask\" | \"allow\" | \"deny\"`, default `allow`)."
        },
        "protectTags": {
          "default": false,
          "description": "When `true`, text inside `<dcp-protected> … </dcp-protected>` is preserved verbatim across compression.",
          "type": "boolean"
        },
        "protectUserMessages": {
          "default": false,
          "description": "When `true`, user messages are protected from compression.",
          "type": "boolean"
        },
        "protectedTools": {
          "default": [
            "task",
            "skill"
          ],
          "description": "Tool names whose verbatim output is appended in `<dcp-protected-tools>` when their range is compressed.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "showCompression": {
          "default": false,
          "description": "When `true`, render `<dcp-block>` wrapper comments for human inspection.",
          "type": "boolean"
        },
        "summaryBuffer": {
          "default": true,
          "description": "When `true`, summaries are buffered through the prompt-engineering append step.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "CompressMode": {
      "description": "How the active `compress` tool operates (SPEC.md §10.2: `compress.mode`).\n\n`Range` covers a contiguous span of messages; `Message` covers an individual non-contiguous message. The variants intentionally match [`dcp_types::CompressionMode`].",
      "oneOf": [
        {
          "description": "A contiguous range of messages.",
          "enum": [
            "range"
          ],
          "type": "string"
        },
        {
          "description": "A single message.",
          "enum": [
            "message"
          ],
          "type": "string"
        }
      ]
    },
    "DeduplicationConfig": {
      "description": "`strategies.deduplication` (SPEC.md §10.2).",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Master switch for the deduplicate strategy.",
          "type": "boolean"
        },
        "protectedTools": {
          "default": [],
          "description": "Tools the deduplicate strategy must skip.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "ExperimentalConfig": {
      "description": "Experimental feature flags (SPEC.md §10.2 — `experimental`).",
      "properties": {
        "allowSubagents": {
          "default": false,
          "description": "Allow experimental sub-agent inlining (SPEC.md §11.6).",
          "type": "boolean"
        },
        "customPrompts": {
          "default": false,
          "description": "Allow programmatic prompt overrides.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "LimitValue": {
      "anyOf": [
        {
          "format": "uint64",
          "type": "integer"
        },
        {
          "pattern": "^\\d{1,3}%$",
          "type": "string"
        }
      ]
    },
    "ManualModeConfig": {
      "description": "Manual mode flags (SPEC.md §10.2 — `manualMode`).",
      "properties": {
        "automaticStrategies": {
          "default": true,
          "description": "When `false` and `enabled == true`, automatic strategies are suspended.",
          "type": "boolean"
        },
        "enabled": {
          "default": false,
          "description": "When `true`, the host drives the library through slash commands.",
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "NotificationConfig": {
      "description": "Host-facing notification preferences (SPEC.md §10.2 — `notification`).",
      "properties": {
        "kind": {
          "allOf": [
            {
              "$ref": "#/definitions/NotificationKind"
            }
          ],
          "default": "chat",
          "description": "Render surface (`\"chat\" | \"toast\"`, default `chat`)."
        },
        "level": {
          "allOf": [
            {
              "$ref": "#/definitions/NotificationLevel"
            }
          ],
          "default": "detailed",
          "description": "Verbosity (`\"off\" | \"minimal\" | \"detailed\"`, default `detailed`)."
        }
      },
      "type": "object"
    },
    "NotificationKind": {
      "description": "Surface where notifications are rendered (SPEC.md §10.2: `notification.kind`).",
      "oneOf": [
        {
          "description": "Inline chat notification (default).",
          "enum": [
            "chat"
          ],
          "type": "string"
        },
        {
          "description": "Out-of-band toast / popup.",
          "enum": [
            "toast"
          ],
          "type": "string"
        }
      ]
    },
    "NotificationLevel": {
      "description": "Verbosity level of host-facing notifications (SPEC.md §10.2: `notification.level`).",
      "oneOf": [
        {
          "description": "Notifications are suppressed entirely.",
          "enum": [
            "off"
          ],
          "type": "string"
        },
        {
          "description": "One-line summaries only.",
          "enum": [
            "minimal"
          ],
          "type": "string"
        },
        {
          "description": "Full structured notifications (default).",
          "enum": [
            "detailed"
          ],
          "type": "string"
        }
      ]
    },
    "NudgeForce": {
      "description": "Internal phantom type used purely by [`schemars::JsonSchema`] when generating the JSON schema for a [`crate::CompressConfig`] field of type [`NudgeForce`]. Callers should never use this type directly.",
      "oneOf": [
        {
          "description": "Strong nudge tone.",
          "enum": [
            "strong"
          ],
          "type": "string"
        },
        {
          "description": "Soft nudge tone (default).",
          "enum": [
            "soft"
          ],
          "type": "string"
        }
      ]
    },
    "Permission": {
      "description": "Whether the host has granted permission to run the `compress` tool (SPEC.md §10.2: `compress.permission`).\n\nVariant names match [`dcp_types::CompressPermission`]; `Allow` is the default.",
      "oneOf": [
        {
          "description": "The host must be prompted before each compression.",
          "enum": [
            "ask"
          ],
          "type": "string"
        },
        {
          "description": "Compression may run without further consent.",
          "enum": [
            "allow"
          ],
          "type": "string"
        },
        {
          "description": "Compression is not allowed.",
          "enum": [
            "deny"
          ],
          "type": "string"
        }
      ]
    },
    "PurgeErrorsConfig": {
      "description": "`strategies.purgeErrors` (SPEC.md §10.2).",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Master switch for the purge-errors strategy.",
          "type": "boolean"
        },
        "protectedTools": {
          "default": [],
          "description": "Tools the purge-errors strategy must skip.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "turns": {
          "default": 4,
          "description": "Turn-age threshold. Range: `1..=100`, default `4`.",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    },
    "StaleFileReadsConfig": {
      "description": "`strategies.staleFileReads` (SPEC.md §10.2).",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Master switch for the stale-file-reads strategy.",
          "type": "boolean"
        },
        "protectedTools": {
          "default": [],
          "description": "Tools the stale-file-reads strategy must skip.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "trackedTools": {
          "default": [
            "read",
            "write",
            "edit",
            "multiedit"
          ],
          "description": "Tool names tracked by stale-file-reads. Default `[\"read\",\"write\",\"edit\",\"multiedit\"]`.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "StrategiesConfig": {
      "description": "`strategies` (SPEC.md §10.2).",
      "properties": {
        "deduplication": {
          "allOf": [
            {
              "$ref": "#/definitions/DeduplicationConfig"
            }
          ],
          "default": {
            "enabled": true,
            "protectedTools": []
          },
          "description": "Deduplication strategy knobs."
        },
        "purgeErrors": {
          "allOf": [
            {
              "$ref": "#/definitions/PurgeErrorsConfig"
            }
          ],
          "default": {
            "enabled": true,
            "protectedTools": [],
            "turns": 4
          },
          "description": "Purge-errors strategy knobs."
        },
        "staleFileReads": {
          "allOf": [
            {
              "$ref": "#/definitions/StaleFileReadsConfig"
            }
          ],
          "default": {
            "enabled": true,
            "protectedTools": [],
            "trackedTools": [
              "read",
              "write",
              "edit",
              "multiedit"
            ]
          },
          "description": "Stale-file-reads strategy knobs."
        }
      },
      "type": "object"
    },
    "TurnProtectionConfig": {
      "description": "Turn-protection knobs (SPEC.md §10.2 — `turnProtection`).",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Reserved master switch.",
          "type": "boolean"
        },
        "turns": {
          "default": 4,
          "description": "Number of recent turns shielded from compression suggestions when `enabled == true`. Range: `0..=100`, default `4`.",
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "type": "object"
    }
  },
  "description": "JSON Schema for the dynamic_context_pruning library",
  "properties": {
    "cacheStabilityMode": {
      "allOf": [
        {
          "$ref": "#/definitions/CacheStabilityMode"
        }
      ],
      "default": "agent-message",
      "description": "Cache stability gate (`\"aggressive\" | \"agent-message\" | \"manual\"`)."
    },
    "commands": {
      "allOf": [
        {
          "$ref": "#/definitions/CommandsConfig"
        }
      ],
      "default": {
        "enabled": true,
        "protectedTools": []
      },
      "description": "Slash-command configuration."
    },
    "compress": {
      "allOf": [
        {
          "$ref": "#/definitions/CompressConfig"
        }
      ],
      "default": {
        "iterationNudgeThreshold": 15,
        "maxContextLimit": 100000,
        "maxSummaryChars": 32768,
        "minContextLimit": 50000,
        "mode": "range",
        "modelMaxLimits": {},
        "modelMinLimits": {},
        "nudgeForce": "soft",
        "nudgeFrequency": 5,
        "permission": "allow",
        "protectTags": false,
        "protectUserMessages": false,
        "protectedTools": [
          "task",
          "skill"
        ],
        "showCompression": false,
        "summaryBuffer": true
      },
      "description": "Compress tool configuration."
    },
    "debug": {
      "default": false,
      "description": "Verbose telemetry / debug log output.",
      "type": "boolean"
    },
    "enabled": {
      "default": true,
      "description": "Master switch (SPEC.md §10.2).",
      "type": "boolean"
    },
    "experimental": {
      "allOf": [
        {
          "$ref": "#/definitions/ExperimentalConfig"
        }
      ],
      "default": {
        "allowSubagents": false,
        "customPrompts": false
      },
      "description": "Experimental flags."
    },
    "manualMode": {
      "allOf": [
        {
          "$ref": "#/definitions/ManualModeConfig"
        }
      ],
      "default": {
        "automaticStrategies": true,
        "enabled": false
      },
      "description": "Manual mode flags."
    },
    "notification": {
      "allOf": [
        {
          "$ref": "#/definitions/NotificationConfig"
        }
      ],
      "default": {
        "kind": "chat",
        "level": "detailed"
      },
      "description": "Notification preferences."
    },
    "protectedFilePatterns": {
      "default": [],
      "description": "Project-wide protected file globs (SPEC.md §5.1, §5.3).",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "strategies": {
      "allOf": [
        {
          "$ref": "#/definitions/StrategiesConfig"
        }
      ],
      "default": {
        "deduplication": {
          "enabled": true,
          "protectedTools": []
        },
        "purgeErrors": {
          "enabled": true,
          "protectedTools": [],
          "turns": 4
        },
        "staleFileReads": {
          "enabled": true,
          "protectedTools": [],
          "trackedTools": [
            "read",
            "write",
            "edit",
            "multiedit"
          ]
        }
      },
      "description": "Strategy configuration."
    },
    "turnProtection": {
      "allOf": [
        {
          "$ref": "#/definitions/TurnProtectionConfig"
        }
      ],
      "default": {
        "enabled": false,
        "turns": 4
      },
      "description": "Turn-protection knobs."
    }
  },
  "title": "dynamic_context_pruning configuration",
  "type": "object"
}