{
  "name": "@qdang46/opencode-dcp-plugin",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "OpenCode plugin that optimizes token usage by pruning obsolete tool outputs from conversation context (full parity port of @tarquinen/opencode-dcp, rebranded as ◆ DCP rust)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "oc-plugin": ["server", "tui"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./tui.tsx",
      "default": "./tui.tsx"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsup",
    "typecheck": "[ -d node_modules/.ss ] || (echo 'restore devDeps first' && false) && tsc --noEmit",
    "dev": "opencode plugin dev",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "context",
    "pruning",
    "dcp",
    "tokens"
  ],
  "license": "MIT",
  "homepage": "https://github.com/quangdang46/dynamic_context_pruning",
  "bugs": {
    "url": "https://github.com/quangdang46/dynamic_context_pruning/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quangdang46/dynamic_context_pruning.git",
    "directory": "opencode-dcp-plugin"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.3",
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "solid-js": "^1.9.12"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@opencode-ai/sdk": "^1.4.3",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.18",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "@types/node": "^26.1.1",
    "solid-js": "^1.9.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "lib/",
    "tui.tsx",
    "dcp.schema.json",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  }
}
